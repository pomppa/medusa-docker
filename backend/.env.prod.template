# Production backend env. Copy to backend/.env.prod and fill in every
# REPLACE_ME placeholder before booting the stack.
#
# Loaded by docker-compose.prod.yml via env_file, after (and overriding)
# backend/.env from the base compose file.

# Secrets. Generate fresh random strings for every deployment,
# e.g. `openssl rand -hex 32`.
JWT_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING
COOKIE_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# Database & cache. The password in DATABASE_URL must match
# POSTGRES_PASSWORD in the postgres service env (docker-compose.yml).
# REDIS_URL uses the internal docker hostname; no secret to replace.
DATABASE_URL=postgres://postgres:REPLACE_ME@postgres:5432/medusa-docker
REDIS_URL=redis://redis:6379

# CORS origins - set to the public URLs of your storefront and admin.
STORE_CORS=https://shop.example.com
ADMIN_CORS=https://admin.example.com
AUTH_CORS=https://shop.example.com,https://admin.example.com
