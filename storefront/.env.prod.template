# Production storefront env. Copy to storefront/.env.prod and fill in
# every REPLACE_ME placeholder before booting the stack.
#
# This file is used in two ways by the prod workflow:
#
# 1) Runtime env for the storefront container
#    -> loaded via env_file in docker-compose.prod.yml
#    -> covers server-side Next.js code (middleware, route handlers)
#
# 2) BUILD-TIME args for `next build` that INLINE NEXT_PUBLIC_* into
#    the client JavaScript bundle
#    -> docker-compose.prod.yml reads these from SHELL env (via
#       build.args: ${NEXT_PUBLIC_*}), not from env_file
#    -> therefore source this file before `docker compose up --build`:
#
#         set -a; . storefront/.env.prod; set +a
#         docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#           --profile storefront up --build -d

# Public backend URL used by BOTH server-side fetches and the browser
# bundle. In production this is the public URL of your Medusa backend.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=

# Server-to-server URL used by SSR fetches inside the docker network.
# Usually http://backend:9000 for docker-compose deploys, or the same
# public URL as NEXT_PUBLIC_MEDUSA_BACKEND_URL if the storefront runs
# outside docker.
MEDUSA_BACKEND_URL=http://backend:9000

# Publishable API key tied to the prod sales channel. Create one in
# the admin UI at <backend-url>/app/settings/publishable-api-keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_ME

# Public storefront URL (used for metadata, canonical links, sitemaps).
NEXT_PUBLIC_BASE_URL=

# Default region (ISO-2 lowercase).
NEXT_PUBLIC_DEFAULT_REGION=us

# Stripe (optional).
NEXT_PUBLIC_STRIPE_KEY=

# Medusa Payments (optional).
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

# Next.js revalidation secret. Generate with `openssl rand -hex 32`.
REVALIDATE_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# Medusa Cloud S3 (optional).
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
