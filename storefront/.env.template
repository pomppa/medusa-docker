# Your Medusa backend URL. When running in docker-compose alongside the
# backend service, use http://backend:9000 for server-to-server requests.
# The browser-facing NEXT_PUBLIC_MEDUSA_BACKEND_URL should point at the
# host-mapped port (http://localhost:9000).
MEDUSA_BACKEND_URL=http://backend:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key tied to your sales channel. Create one in the admin
# dashboard at http://localhost:9000/app/settings/publishable-api-keys
# See: https://docs.medusajs.com/resources/storefront-development/publishable-api-keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_test

# Your storefront URL
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Default region (ISO-2 lowercase)
NEXT_PUBLIC_DEFAULT_REGION=us

# Stripe (optional)
# See: https://docs.medusajs.com/resources/commerce-modules/payment/payment-provider/stripe
NEXT_PUBLIC_STRIPE_KEY=

# Medusa payments (optional)
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

# Next.js revalidation secret
REVALIDATE_SECRET=supersecret

# Medusa Cloud S3 (optional)
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
